select surf_pocket4, protein and id [617,653,656,659,1127,1135,2889,2956,1061,665,647,663] 
set surface_color,  pcol4, surf_pocket4 
set_color pcol5 = [0.902,0.361,0.682]
select surf_pocket5, protein and id [4349,4352,4354,4355,4357,4358,3734,4295,4306,3735,4305,4297,3677,3680,3683,3675,3726] 
set surface_color,  pcol5, surf_pocket5 
set_color pcol6 = [0.702,0.278,0.341]
select surf_pocket6, protein and id [3260,3262,3266,4762,4833,4897,3332,3217,3160,3220,3225,4774,4817,4822,4712,4777] 
set surface_color,  pcol6, surf_pocket6 
set_color pcol7 = [0.902,0.522,0.361]
select surf_pocket7, protein and id [1133,1135,2819,2821,2886,2838,2883,2827,561,562,2768,2772,454,1180] 
set surface_color,  pcol7, surf_pocket7 
set_color pcol8 = [0.702,0.596,0.278]
select surf_pocket8, protein and id [446,449,450,452,457,459,2712,1254,1256,383,384,387,403,398,2719,2672,2674,1330,381] 
set surface_color,  pcol8, surf_pocket8 
   

deselect

orient
