# ============================================================
# Large raw data directories — deposited at Zenodo
# ============================================================

# CHARMM-GUI solvated system inputs (~73 GB) — exclude bulk, keep .mdp files
02_md_inputs/**
!02_md_inputs/
!02_md_inputs/**/
!02_md_inputs/**/*.mdp

# Complex MD production trajectories (~24 GB)
02_md_simulations/complex_md/

# Per-frame fpocket PDB outputs (~12 GB)
03_pocket_analysis/fpocket_results/

# Per-compound AMBER/GROMACS MM-GBSA run directories (~99 GB)
04_virtual_screening/mmgbsa/

# Per-compound AutoDock Vina docking output pdbqt files (~219 MB)
04_virtual_screening/docking_results/

# ============================================================
# Large trajectory PDB dumps inside tracked sim dirs
# ============================================================
02_md_simulations/*/metadynamics/*/protein_traj_metad.pdb
02_md_simulations/*/metadynamics/*/protein_traj_metad_filtered.pdb
02_md_simulations/*/persistence_gate/*/protein_traj.pdb

# AlphaFold MSA files (large, re-downloadable from AF3 server)
*.a3m

# Excel / binary workbooks (not diff-friendly; keep .csv instead)
*.xlsx
*.xls

# Log files in root (per-run noise)
logs/

